# Copy to `.env` and fill in values. Never commit `.env`.
# From repository root: `load_dotenv()` loads this file (see `issue_tracker_service` / Alembic).

# --- Trello (OAuth; required for the API service) ---
TRELLO_API_KEY=
TRELLO_API_SECRET=
# Optional: override default `http://localhost:8000/auth/callback` for OAuth
# TRELLO_CALLBACK_URL=

# --- Database (Supabase / Cloud SQL / local Postgres or SQLite for dev) ---
# Example local Postgres: postgresql+psycopg://app:dev@127.0.0.1:5432/issue_tracker
# Production Cloud Run reads DATABASE_URL from GCP Secret Manager (Terraform).
DATABASE_URL=

# --- Process (Cloud Run binds 8080; local uvicorn on 8000) ---
# The app reads PORT only via the process/command line (--port).
# PORT=8000

# --- HW3: OpenTelemetry (OTLP/HTTP; traces + HTTP metrics for dashboards) ---
# Local dev: leave unset or set OTEL_SDK_DISABLED=true to skip exporters (also used in tests/CI).
# OTEL_SDK_DISABLED=true
# OTEL_SERVICE_NAME=issue-tracker-service
# Optional resource labels (comma-separated); Grafana wizard may suggest these:
# OTEL_RESOURCE_ATTRIBUTES=service.namespace=...,deployment.environment=production
#
# Single OTLP base URL (traces at .../v1/traces, metrics at .../v1/metrics are derived in code), or set TRACES/METRICS endpoints explicitly:
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-REGION.grafana.net/otlp
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://example.com/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=https://example.com/v1/metrics
# Per OTel, header values can be URL-encoded (e.g. Basic%20...); the service decodes for Grafana:
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20...,Another-Header=value

# --- E2E / adapter tests against a deployed service (`tests/e2e/`) ---
# Match `tests/e2e/conftest.py`. Obtain SERVICE_SESSION_TOKEN from a real OAuth flow against the deployed app.
# SERVICE_BASE_URL=https://YOUR-CLOUD-RUN-HOST-xxxxx.us-central1.run.app
# SERVICE_SESSION_TOKEN=
# Trello-backed e2e (same as CircleCI, when running real API tests) also use:
# TRELLO_TOKEN=
# TRELLO_BOARD_ID=

# --- Future HW3: AI (T1) ---
# ANTHROPIC_API_KEY=
# Allow AI to perform write operations (create/update/delete) on Trello boards.
# Set to "true" in production if AI mutations are desired; defaults to unset (no mutations).
# AI_ALLOW_MUTATIONS=true
