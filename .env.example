# Copy to `.env` and fill in values. Never commit `.env`.
# From repository root: `load_dotenv()` loads this file (see `issue_tracker_service` / Alembic).

# --- Trello (OAuth; required for the API service) ---
TRELLO_API_KEY=
TRELLO_API_SECRET=
TRELLO_CALLBACK_URL=http://localhost:8000/auth/callback

# --- Database ---
# Example local Postgres: postgresql+psycopg://app:dev@127.0.0.1:5432/issue_tracker
# On Render, use the value linked from the Postgres add-on (often exposed as `DATABASE_URL`).
# Production Cloud Run reads DATABASE_URL from GCP Secret Manager (Terraform).
DATABASE_URL=

# --- Process ---
# Render sets `PORT`; Cloud Run uses 8080 in the container image.
# The app is started with uvicorn `--port` from the process manager.
# PORT=8000

# --- HW3: AI provider & models ---
# Default LLM stack: claude or openai. Each POST /ai/chat may override for that request with header X-AI-Provider: claude | openai (both keys should exist if you use overrides).
AI_PROVIDER=claude

# --- Anthropic Claude (when using Claude as default or X-AI-Provider: claude) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# --- OpenAI (when using OpenAI as default or X-AI-Provider: openai) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional tuning (shared by Claude and OpenAI implementations).
AI_MAX_TOOL_HOPS=6
AI_MAX_TOKENS=1024
# Allow AI to perform write operations (create/update/delete) on Trello boards.
AI_ALLOW_MUTATIONS=false

# When true, the model's final assistant message must be JSON matching StructuredAIEnvelope
# {"reply": "...", "rationale": "..." | null}; invalid JSON raises AIStructuredOutputError (HTTP 422 from /ai/chat).
AI_STRUCTURED_OUTPUT=false

# HTTP resilience around upstream LLM calls (both providers): retries with full jitter between attempts.
AI_HTTP_MAX_ATTEMPTS=4
AI_HTTP_RETRY_BASE_S=0.1
AI_HTTP_RETRY_MAX_S=2.0

# Optional: POST /ai/chat may pass context.idempotency_key (string, max 128 chars). When set, the OpenAI tool
# dispatcher deduplicates mutating tool calls in-process for identical tool name + arguments (see ai_client_api.resilience).

# --- HW3: Chat backend selection (cross-vertical integration) ---
# One of: local | slack
CHAT_BACKEND=local
# Required when CHAT_BACKEND=slack.
# SLACK_BOT_TOKEN=

# --- Telemetry ---
# Prometheus scrape endpoint at /metrics unless disabled.
# PROMETHEUS_METRICS_ENABLED=true
#
# Local dev/CI: leave unset or set OTEL_SDK_DISABLED=true to skip OTLP exporters.
# OTEL_SDK_DISABLED=true
# OTEL_SERVICE_NAME=issue-tracker-service
# Optional resource labels (comma-separated); Grafana wizard may suggest these:
# OTEL_RESOURCE_ATTRIBUTES=service.namespace=...,deployment.environment=production
#
# Single OTLP base URL (traces at .../v1/traces and metrics at .../v1/metrics are derived in code), or set TRACES/METRICS endpoints explicitly:
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-REGION.grafana.net/otlp
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://example.com/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=https://example.com/v1/metrics
# Use plain HTTP header values (recommended):
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic ...,Another-Header=value

# --- AI telemetry cost model (approximate USD/request) ---
# Used by issue_tracker_ai_anthropic_cost_usd_total and
# issue_tracker_ai_anthropic_request_cost_usd.
# AI_COST_INPUT_PER_MILLION_USD=3.0
# AI_COST_OUTPUT_PER_MILLION_USD=15.0

# --- CORS (Next.js frontend) ---
# Comma-separated list of allowed origins. Include the Vercel URL in production.
CORS_ALLOW_ORIGINS=http://localhost:3000

# --- E2E / adapter tests against a deployed service (`tests/e2e/`) ---
# Match `tests/e2e/conftest.py`. Obtain SERVICE_SESSION_TOKEN from a real OAuth flow.
# Cloud Run: SERVICE_BASE_URL from `terraform output -raw service_url`
# Render:     SERVICE_BASE_URL=https://your-service.onrender.com
# SERVICE_BASE_URL=
# SERVICE_SESSION_TOKEN=
# TRELLO_TOKEN=
# TRELLO_BOARD_ID=
