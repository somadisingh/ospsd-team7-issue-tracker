# Copy this file to `.env` (git-ignored) and fill in real secrets.
# The server loads .env at startup via python-dotenv.

# -------- Trello OAuth (existing) ---------------------------------------
TRELLO_API_KEY=
TRELLO_API_SECRET=
TRELLO_CALLBACK_URL=http://localhost:8000/auth/callback

# -------- Anthropic Claude (HW3 AI integration) -------------------------
ANTHROPIC_API_KEY=

# Optional tuning. Safe defaults will be used if unset.
CLAUDE_MODEL=claude-sonnet-4-5
AI_MAX_TOOL_HOPS=6
AI_ALLOW_MUTATIONS=false
AI_MAX_TOKENS=1024

# -------- CORS for the Next.js frontend ---------------------------------
# Comma-separated list of allowed origins. Include the Vercel URL here.
CORS_ALLOW_ORIGINS=http://localhost:3000
