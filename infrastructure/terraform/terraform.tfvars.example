project_id             = "your-gcp-project-id"
region                 = "us-central1"
artifact_repository_id = "issue-tracker"
image_name             = "issue-tracker-service"
image_tag              = "latest"

# Defaults: Terraform manages first secret versions — still need DATABASE_URL/Trello as TF_VAR_* / below.
manage_secret_versions_in_terraform = true
deploy_cloud_run_service            = true

# --- External payloads only (GCP Console / `gcloud secrets versions add`) -------------
# Uncomment and omit database_url / trello_* from Terraform entirely:
#
# manage_secret_versions_in_terraform = false
# deploy_cloud_run_service           = false
# provision_anthropic_secret_shell  = false
# provision_openai_secret_shell      = false
# provision_otlp_headers_secret_shell = false
#
# 1) terraform apply -var-file=secrets.tfvars   # creates shells + Artifact Registry IAM; no Cloud Run
# 2) Add payloads for terraform output secret_manager_*_id names
# 3) terraform apply with deploy_cloud_run_service = true

# See README — use CI TF_VAR_* where possible; never commit real credential files.

database_url       = "postgresql+psycopg://...@...:5432/postgres"
trello_api_key     = "(from Trello Power-Up Admin)"
trello_api_secret  = "(consumer secret)"
trello_callback_url = ""

# --- Plain vs secret (Mode A: manage_secret_versions_in_terraform = false) -----------------
# Plain OTLP endpoint (safe in tfvars / VCS if this file is not gitignored):
# otel_exporter_otlp_endpoint = "https://otlp-gateway-prod-us-east-2.grafana.net/otlp"
#
# OTLP auth headers (Mode A): NEVER put tokens in tfvars.
# 1) provision_otlp_headers_secret_shell = true, otlp_headers_secret_version = ""
# 2) terraform apply  (creates secret shell; Cloud Run does not mount headers yet)
# 3) printf '%s' 'Authorization=Basic …' | gcloud secrets versions add issue-tracker-otlp-headers --project=PROJECT --data-file=-
# 4) otlp_headers_secret_version = "1"  (use output of `gcloud secrets versions list`)
# 5) terraform apply  (mounts OTEL_EXPORTER_OTLP_HEADERS from that version)

# Optional: add non-secret env vars without editing main.tf (merged into Cloud Run).
# cloud_run_plain_environment_variables = {
#   CORS_ALLOW_ORIGINS = "https://your-github-pages.github.io"
#   CHAT_BACKEND       = "slack"
# }
# SLACK_BOT_TOKEN via Secret Manager + cloud_run_secret_environment_variables (never plaintext in tfvars).

# Optional: mount existing Secret Manager secrets by id (same project). Runtime SA gets accessor IAM.
# cloud_run_secret_environment_variables = {
#   MY_API_TOKEN = "issue-tracker-my-api-token"
# }

otel_service_name   = "issue-tracker-service"
ai_allow_mutations  = true
